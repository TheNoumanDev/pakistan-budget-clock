---
interface Props {
  lang?: 'en' | 'ur';
}

const { lang = 'en' } = Astro.props;

import en from '../i18n/en.json';
import ur from '../i18n/ur.json';

const t = lang === 'ur' ? ur : en;

const sourceLinks = [
  { label: 'Budget 2025-26', url: 'https://www.finance.gov.pk/fb_2025_26.html' },
  { label: 'Budget in Brief', url: 'https://finance.gov.pk/budget/budget_2025_26/budget_in_brief_10062025.pdf' },
  { label: 'Fiscal Operations', url: 'https://www.finance.gov.pk/fiscal_main.html' },
  { label: 'Economic Survey', url: 'https://www.finance.gov.pk/survey_2025.html' },
];
---

<section class="py-12 md:py-16 border-t border-white/5">
  <div class="section-container">
    <h2 class="text-sm uppercase tracking-[0.2em] text-gray-500 text-center mb-4">
      {t.sources.title}
    </h2>
    <p class="text-gray-600 text-center text-sm mb-6">
      {t.sources.text}
    </p>

    <!-- Source Pills -->
    <div class="flex flex-wrap justify-center gap-2 mb-6">
      {sourceLinks.map(link => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 px-3 py-1.5 bg-white/5 rounded-full border border-white/10 text-sm text-gray-400 hover:border-white/20 hover:text-white transition-colors"
        >
          {link.label}
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      ))}
    </div>

    <!-- Methodology Link -->
    <div class="text-center">
      <a
        href="/methodology"
        class="inline-flex items-center gap-2 text-debt-red hover:text-red-400 text-sm font-medium transition-colors"
      >
        {t.sources.viewMethodology}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
