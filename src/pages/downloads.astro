---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const url = new URL(Astro.request.url);
const lang = url.searchParams.get('lang') === 'ur' ? 'ur' : 'en';

// R2 CDN for budget documents
// To use custom domain later: add pakbudgetclock.com to Cloudflare DNS, then set cdn.pakbudgetclock.com
const R2_BASE = 'https://pub-310dbc3bce2b483195676d2847518463.r2.dev';

// Budget documents by fiscal year (only years with PDFs uploaded to R2)
const budgetDocs = [
  {
    year: '2025-26',
    title: 'Federal Budget 2025-26',
    titleUrdu: 'وفاقی بجٹ 2025-26',
    isCurrent: true,
    documents: [
      { name: 'Budget in Brief (English)', nameUrdu: 'بجٹ خلاصہ (انگریزی)', url: `${R2_BASE}/2025-26/Budget_in_Brief_EN.pdf`, size: '2.1 MB' },
      { name: 'Budget in Brief (Urdu)', nameUrdu: 'بجٹ خلاصہ (اردو)', url: `${R2_BASE}/2025-26/Budget_in_Brief_UR.pdf`, size: '2.0 MB' },
      { name: 'Annual Budget Statement', nameUrdu: 'سالانہ بجٹ بیان', url: `${R2_BASE}/2025-26/Annual_Budget_Statement.pdf`, size: '1.8 MB' },
    ]
  },
  {
    year: '2024-25',
    title: 'Federal Budget 2024-25',
    titleUrdu: 'وفاقی بجٹ 2024-25',
    documents: [
      { name: 'Budget in Brief', nameUrdu: 'بجٹ خلاصہ', url: `${R2_BASE}/2024-25/Budget_in_Brief.pdf`, size: '2.0 MB' },
    ]
  },
  {
    year: '2023-24',
    title: 'Federal Budget 2023-24',
    titleUrdu: 'وفاقی بجٹ 2023-24',
    documents: [
      { name: 'Budget in Brief', nameUrdu: 'بجٹ خلاصہ', url: `${R2_BASE}/2023-24/Budget_in_Brief.pdf`, size: '1.9 MB' },
    ]
  },
  {
    year: '2022-23',
    title: 'Federal Budget 2022-23',
    titleUrdu: 'وفاقی بجٹ 2022-23',
    documents: [
      { name: 'Budget in Brief', nameUrdu: 'بجٹ خلاصہ', url: `${R2_BASE}/2022-23/Budget_in_Brief.pdf`, size: '1.8 MB' },
    ]
  },
  {
    year: '2021-22',
    title: 'Federal Budget 2021-22',
    titleUrdu: 'وفاقی بجٹ 2021-22',
    documents: [
      { name: 'Budget in Brief', nameUrdu: 'بجٹ خلاصہ', url: `${R2_BASE}/2021-22/Budget_in_Brief.pdf`, size: '1.7 MB' },
    ]
  },
  {
    year: '2020-21',
    title: 'Federal Budget 2020-21',
    titleUrdu: 'وفاقی بجٹ 2020-21',
    documents: [
      { name: 'Budget in Brief', nameUrdu: 'بجٹ خلاصہ', url: `${R2_BASE}/2020-21/Budget_in_Brief.pdf`, size: '1.6 MB' },
    ]
  },
  {
    year: '2019-20',
    title: 'Federal Budget 2019-20',
    titleUrdu: 'وفاقی بجٹ 2019-20',
    documents: [
      { name: 'Budget in Brief', nameUrdu: 'بجٹ خلاصہ', url: `${R2_BASE}/2019-20/Budget_in_Brief.pdf`, size: '1.5 MB' },
    ]
  },
  {
    year: '2018-19',
    title: 'Federal Budget 2018-19',
    titleUrdu: 'وفاقی بجٹ 2018-19',
    documents: [
      { name: 'Budget in Brief', nameUrdu: 'بجٹ خلاصہ', url: `${R2_BASE}/2018-19/Budget_in_Brief.pdf`, size: '1.4 MB' },
    ]
  },
  {
    year: '2017-18',
    title: 'Federal Budget 2017-18',
    titleUrdu: 'وفاقی بجٹ 2017-18',
    documents: [
      { name: 'Budget in Brief', nameUrdu: 'بجٹ خلاصہ', url: `${R2_BASE}/2017-18/Budget_in_Brief.pdf`, size: '1.3 MB' },
    ]
  },
  {
    year: '2016-17',
    title: 'Federal Budget 2016-17',
    titleUrdu: 'وفاقی بجٹ 2016-17',
    documents: [
      { name: 'Budget in Brief', nameUrdu: 'بجٹ خلاصہ', url: `${R2_BASE}/2016-17/Budget_in_Brief.pdf`, size: '1.2 MB' },
    ]
  },
  {
    year: '2015-16',
    title: 'Federal Budget 2015-16',
    titleUrdu: 'وفاقی بجٹ 2015-16',
    documents: [
      { name: 'Budget in Brief', nameUrdu: 'بجٹ خلاصہ', url: `${R2_BASE}/2015-16/Budget_in_Brief.pdf`, size: '1.1 MB' },
    ]
  },
];

// Fiscal Operations Reports
const fiscalOps = [
  { name: 'Fiscal Operations FY 2025-26 (H1)', nameUrdu: 'مالیاتی آپریشنز 2025-26 (پہلی ششماہی)', url: `${R2_BASE}/fiscal-ops/FY2025-26_H1.pdf`, size: '500 KB' },
  { name: 'Fiscal Operations FY 2024-25 (Full Year)', nameUrdu: 'مالیاتی آپریشنز 2024-25 (مکمل سال)', url: `${R2_BASE}/fiscal-ops/FY2024-25_Full_Year.pdf`, size: '600 KB' },
  { name: 'Fiscal Operations FY 2023-24 (Full Year)', nameUrdu: 'مالیاتی آپریشنز 2023-24 (مکمل سال)', url: `${R2_BASE}/fiscal-ops/FY2023-24_Full_Year.pdf`, size: '550 KB' },
  { name: 'Fiscal Operations FY 2022-23 (Full Year)', nameUrdu: 'مالیاتی آپریشنز 2022-23 (مکمل سال)', url: `${R2_BASE}/fiscal-ops/FY2022-23_Full_Year.pdf`, size: '520 KB' },
];

// Provincial & Comparison Data
const provincialDocs = [
  { name: 'Punjab Budget 2025-26', nameUrdu: 'پنجاب بجٹ 2025-26', url: `${R2_BASE}/other/Punjab_Budget_2025-26.pdf`, size: '1.5 MB' },
  { name: 'India Budgets Comparison (2015-2025)', nameUrdu: 'بھارت بجٹ موازنہ (2015-2025)', url: `${R2_BASE}/other/India_Budgets_2015-2025.pdf`, size: '800 KB' },
];

// External links (not hosted on R2)
const externalLinks = [
  { name: 'Pakistan Economic Survey 2024-25', nameUrdu: 'پاکستان اقتصادی سروے', url: 'https://www.finance.gov.pk/survey_2025.html' },
  { name: 'State Bank of Pakistan Annual Report', nameUrdu: 'سٹیٹ بینک سالانہ رپورٹ', url: 'https://www.sbp.org.pk/reports/annual/index.htm' },
  { name: 'Ministry of Finance Portal', nameUrdu: 'وزارت خزانہ پورٹل', url: 'https://www.finance.gov.pk' },
];
---

<Layout title={lang === 'ur' ? 'بجٹ ڈاؤن لوڈز | پاکستان بجٹ کلاک' : 'Budget Downloads | Pakistan Budget Clock'} lang={lang}>
  <Navbar lang={lang} />

  <main class="py-12 md:py-16">
    <div class="section-container">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <h1 class="text-3xl md:text-4xl font-bold mb-4 text-white text-center">
          {lang === 'ur' ? 'بجٹ دستاویزات ڈاؤن لوڈ کریں' : 'Download Budget Documents'}
        </h1>
        <p class="text-gray-400 text-lg mb-12 text-center">
          {lang === 'ur' ? 'پاکستان کے وفاقی بجٹ کی سرکاری دستاویزات (2015-2026)' : 'Official Federal Budget documents from Pakistan (2015-2026)'}
        </p>

        <!-- Quick Stats -->
        <div id="overview" class="grid grid-cols-3 gap-4 mb-12">
          <div class="bg-dark-800 rounded-lg p-4 text-center border border-white/10">
            <p class="text-3xl font-bold text-debt-red">11</p>
            <p class="text-sm text-gray-500">{lang === 'ur' ? 'مالی سال' : 'Fiscal Years'}</p>
          </div>
          <div class="bg-dark-800 rounded-lg p-4 text-center border border-white/10">
            <p class="text-3xl font-bold text-education-green">19+</p>
            <p class="text-sm text-gray-500">{lang === 'ur' ? 'دستاویزات' : 'Documents'}</p>
          </div>
          <div class="bg-dark-800 rounded-lg p-4 text-center border border-white/10">
            <p class="text-3xl font-bold text-nfc-blue">PDF</p>
            <p class="text-sm text-gray-500">{lang === 'ur' ? 'فارمیٹ' : 'Format'}</p>
          </div>
        </div>

        <!-- Current Year Highlight -->
        <div id="current-year" class="mb-12 p-6 bg-debt-red/10 border border-debt-red/30 rounded-lg">
          <div class="flex items-center gap-3 mb-4">
            <span class="px-3 py-1 bg-debt-red text-white text-sm font-bold rounded-full">{lang === 'ur' ? 'تازہ ترین' : 'LATEST'}</span>
            <h2 class="text-xl font-bold text-white">{lang === 'ur' ? 'وفاقی بجٹ 2025-26' : 'Federal Budget 2025-26'}</h2>
          </div>
          <div class="grid sm:grid-cols-3 gap-3">
            {budgetDocs[0].documents.map(doc => (
              <a
                href={doc.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 p-4 bg-dark-900 rounded-lg hover:bg-dark-800 transition-colors group"
              >
                <div class="w-10 h-10 bg-debt-red/20 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-debt-red" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="text-white font-medium group-hover:text-debt-red transition-colors">
                    {lang === 'ur' ? doc.nameUrdu : doc.name}
                  </p>
                  <p class="text-xs text-gray-500">{doc.size}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- All Years -->
        <div id="all-budgets" class="mb-12">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <span class="text-2xl">📁</span>
            {lang === 'ur' ? 'تمام مالی سالوں کے بجٹ' : 'All Fiscal Year Budgets'}
          </h2>

          <div class="space-y-4">
            {budgetDocs.slice(1).map(budget => (
              <div class="p-4 bg-dark-800 border border-white/10 rounded-lg">
                <div class="flex items-center justify-between mb-3">
                  <h3 class="font-bold text-white">
                    {lang === 'ur' ? budget.titleUrdu : budget.title}
                  </h3>
                  <span class="text-xs text-gray-500 bg-white/5 px-2 py-1 rounded">FY {budget.year}</span>
                </div>
                <div class="flex flex-wrap gap-2">
                  {budget.documents.map(doc => (
                    <a
                      href={doc.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 px-3 py-2 bg-dark-900 hover:bg-dark-700 rounded-lg text-sm text-gray-300 hover:text-white transition-colors"
                    >
                      <svg class="w-4 h-4 text-debt-red" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                      </svg>
                      {lang === 'ur' ? doc.nameUrdu : doc.name}
                      <span class="text-xs text-gray-600">({doc.size})</span>
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Fiscal Operations Reports -->
        <div id="fiscal-ops" class="mb-12">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <span class="text-2xl">📈</span>
            {lang === 'ur' ? 'مالیاتی آپریشنز رپورٹس' : 'Fiscal Operations Reports'}
          </h2>
          <p class="text-gray-400 text-sm mb-4">
            {lang === 'ur' ? 'حقیقی اخراجات بمقابلہ بجٹ مختص - سرکاری ڈیٹا' : 'Actual spending vs budget allocations - official data'}
          </p>

          <div class="grid sm:grid-cols-2 gap-3">
            {fiscalOps.map(doc => (
              <a
                href={doc.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 p-4 bg-dark-800 border border-white/10 rounded-lg hover:border-white/20 transition-colors group"
              >
                <div class="w-10 h-10 bg-education-green/20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-education-green" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="text-white font-medium group-hover:text-education-green transition-colors">
                    {lang === 'ur' ? doc.nameUrdu : doc.name}
                  </p>
                  <p class="text-xs text-gray-500">{doc.size}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Provincial & Comparison -->
        <div id="provincial" class="mb-12">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <span class="text-2xl">🏛️</span>
            {lang === 'ur' ? 'صوبائی اور موازنہ' : 'Provincial & Comparison'}
          </h2>

          <div class="grid sm:grid-cols-2 gap-3">
            {provincialDocs.map(doc => (
              <a
                href={doc.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 p-4 bg-dark-800 border border-white/10 rounded-lg hover:border-white/20 transition-colors group"
              >
                <div class="w-10 h-10 bg-nfc-blue/20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-nfc-blue" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="text-white font-medium group-hover:text-nfc-blue transition-colors">
                    {lang === 'ur' ? doc.nameUrdu : doc.name}
                  </p>
                  <p class="text-xs text-gray-500">{doc.size}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Other Resources (External Links) -->
        <div id="other-resources" class="mb-12">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <span class="text-2xl">🔗</span>
            {lang === 'ur' ? 'دیگر اہم ذرائع' : 'Other Important Resources'}
          </h2>

          <div class="grid sm:grid-cols-3 gap-4">
            {externalLinks.map(doc => (
              <a
                href={doc.url}
                target="_blank"
                rel="noopener noreferrer"
                class="p-4 bg-dark-800 border border-white/10 rounded-lg hover:border-white/20 transition-colors group"
              >
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 bg-gray-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-white font-medium group-hover:text-gray-300 transition-colors">
                      {lang === 'ur' ? doc.nameUrdu : doc.name}
                    </p>
                    <p class="text-xs text-gray-500 mt-1">{lang === 'ur' ? 'بیرونی لنک' : 'External Link'}</p>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Disclaimer -->
        <div class="p-4 bg-education-green/10 border border-education-green/30 rounded-lg">
          <p class="text-sm text-gray-300">
            <span class="text-education-green font-bold">✓ {lang === 'ur' ? 'قابل اعتماد ہوسٹنگ:' : 'Reliable Hosting:'}</span>
            {lang === 'ur'
              ? ' یہ دستاویزات ہماری CDN پر ہوسٹ کی گئی ہیں تاکہ تیز اور قابل اعتماد ڈاؤن لوڈ یقینی بنایا جا سکے۔ تمام فائلیں وزارت خزانہ پاکستان کی سرکاری دستاویزات ہیں۔'
              : ' These documents are hosted on our CDN for fast and reliable downloads. All files are official documents from the Ministry of Finance Pakistan.'}
          </p>
        </div>

        <!-- Back to Home -->
        <div class="mt-12 pt-8 border-t border-white/10">
          <a
            href={`/${lang === 'ur' ? '?lang=ur' : ''}`}
            class="inline-flex items-center gap-2 text-debt-red hover:text-red-400 font-medium transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            {lang === 'ur' ? 'واپس ہوم پیج' : 'Back to Home'}
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
