---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// Get language from URL query param
const url = new URL(Astro.request.url);
const lang = url.searchParams.get('lang') === 'ur' ? 'ur' : 'en';

import en from '../i18n/en.json';
import ur from '../i18n/ur.json';

const t = lang === 'ur' ? ur : en;

const categoryInfo = {
  debtInterest: { label: 'Debt Servicing', labelUrdu: 'قرض کا سود', color: '#ef4444' },
  nfcTransfers: { label: 'NFC Transfers', labelUrdu: 'این ایف سی منتقلی', color: '#3b82f6' },
  defence: { label: 'Defence', labelUrdu: 'دفاع', color: '#94a3b8' },
  militaryPensions: { label: 'Military Pensions', labelUrdu: 'فوجی پنشن', color: '#78716c' },
  psdp: { label: 'Development (PSDP)', labelUrdu: 'ترقیاتی پروگرام', color: '#84cc16' },
  education: { label: 'Education', labelUrdu: 'تعلیم', color: '#22c55e' },
  health: { label: 'Health', labelUrdu: 'صحت', color: '#14b8a6' },
  other: { label: 'Other', labelUrdu: 'دیگر', color: '#6b7280' }
};
---

<Layout title={lang === 'ur' ? 'بجٹ کا موازنہ | پاکستان بجٹ کلاک' : 'Budget Comparison | Pakistan Budget Clock'} lang={lang}>
  <Navbar lang={lang} />

  <main class="py-12 md:py-16">
    <div class="section-container">
      <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <h1 class="text-3xl md:text-4xl font-bold mb-4 text-white text-center">
          {lang === 'ur' ? '10 سال کا بجٹ موازنہ' : '10-Year Budget Comparison'}
        </h1>
        <p class="text-gray-400 text-lg mb-12 text-center">
          {lang === 'ur' ? 'مالی سال 2015-16 سے 2025-26 تک وفاقی بجٹ کی مکمل تفصیل' : 'Complete federal budget breakdown from FY 2015-16 to FY 2025-26'}
        </p>

        <!-- INDIA VS PAKISTAN COMPARISON (TOP) -->
        <div id="pak-vs-india" class="mb-12 p-6 bg-dark-800 border border-white/10 rounded-lg">
          <h2 class="text-xl font-bold mb-2 text-white">
            {lang === 'ur' ? 'پاکستان بمقابلہ بھارت' : 'Pakistan vs India'}
          </h2>
          <p class="text-gray-500 text-sm mb-6">
            {lang === 'ur' ? 'بجٹ مختص کا فیصد موازنہ (مالی سال 2025-26)' : 'Budget allocation comparison as % of total (FY 2025-26)'}
          </p>

          <div class="grid md:grid-cols-2 gap-8">
            <!-- Comparison Bars -->
            <div class="space-y-6">
              <!-- Debt Interest -->
              <div>
                <p class="text-base font-semibold text-white mb-2">{lang === 'ur' ? 'قرض کا سود' : 'Debt Interest'}</p>
                <div class="flex gap-3 items-center">
                  <span class="text-2xl w-10">🇵🇰</span>
                  <div class="flex-1 bg-white/10 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-debt-red rounded-full" style="width: 46.7%"></div>
                  </div>
                  <span class="text-base text-debt-red font-bold w-16 text-right">46.7%</span>
                </div>
                <div class="flex gap-3 items-center mt-2">
                  <span class="text-2xl w-10">🇮🇳</span>
                  <div class="flex-1 bg-white/10 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-orange-500 rounded-full" style="width: 25%"></div>
                  </div>
                  <span class="text-base text-orange-500 font-bold w-16 text-right">25%</span>
                </div>
              </div>

              <!-- Defence -->
              <div>
                <p class="text-base font-semibold text-white mb-2">{lang === 'ur' ? 'دفاع' : 'Defence'}</p>
                <div class="flex gap-3 items-center">
                  <span class="text-2xl w-10">🇵🇰</span>
                  <div class="flex-1 bg-white/10 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-slate-400 rounded-full" style="width: 14.6%"></div>
                  </div>
                  <span class="text-base text-slate-300 font-bold w-16 text-right">14.6%</span>
                </div>
                <div class="flex gap-3 items-center mt-2">
                  <span class="text-2xl w-10">🇮🇳</span>
                  <div class="flex-1 bg-white/10 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-orange-500 rounded-full" style="width: 8%"></div>
                  </div>
                  <span class="text-base text-orange-500 font-bold w-16 text-right">8%</span>
                </div>
              </div>

              <!-- Education -->
              <div>
                <p class="text-base font-semibold text-white mb-2">{lang === 'ur' ? 'تعلیم' : 'Education'}</p>
                <div class="flex gap-3 items-center">
                  <span class="text-2xl w-10">🇵🇰</span>
                  <div class="flex-1 bg-white/10 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-education-green rounded-full" style="width: 2%"></div>
                  </div>
                  <span class="text-base text-education-green font-bold w-16 text-right">0.64%</span>
                </div>
                <div class="flex gap-3 items-center mt-2">
                  <span class="text-2xl w-10">🇮🇳</span>
                  <div class="flex-1 bg-white/10 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-orange-500 rounded-full" style="width: 8.7%"></div>
                  </div>
                  <span class="text-base text-orange-500 font-bold w-16 text-right">2.9%</span>
                </div>
              </div>

              <!-- Health -->
              <div>
                <p class="text-base font-semibold text-white mb-2">{lang === 'ur' ? 'صحت' : 'Health'}</p>
                <div class="flex gap-3 items-center">
                  <span class="text-2xl w-10">🇵🇰</span>
                  <div class="flex-1 bg-white/10 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-health-teal rounded-full" style="width: 0.5%"></div>
                  </div>
                  <span class="text-base text-health-teal font-bold w-16 text-right">0.13%</span>
                </div>
                <div class="flex gap-3 items-center mt-2">
                  <span class="text-2xl w-10">🇮🇳</span>
                  <div class="flex-1 bg-white/10 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-orange-500 rounded-full" style="width: 6.3%"></div>
                  </div>
                  <span class="text-base text-orange-500 font-bold w-16 text-right">2.1%</span>
                </div>
              </div>

              <!-- Development/Infrastructure -->
              <div>
                <p class="text-base font-semibold text-white mb-2">{lang === 'ur' ? 'ترقیاتی منصوبے' : 'Development/Infra'}</p>
                <div class="flex gap-3 items-center">
                  <span class="text-2xl w-10">🇵🇰</span>
                  <div class="flex-1 bg-white/10 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-psdp-green rounded-full" style="width: 5.7%"></div>
                  </div>
                  <span class="text-base text-psdp-green font-bold w-16 text-right">5.7%</span>
                </div>
                <div class="flex gap-3 items-center mt-2">
                  <span class="text-2xl w-10">🇮🇳</span>
                  <div class="flex-1 bg-white/10 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-orange-500 rounded-full" style="width: 11%"></div>
                  </div>
                  <span class="text-base text-orange-500 font-bold w-16 text-right">11%</span>
                </div>
              </div>
            </div>

            <!-- Key Takeaways -->
            <div class="bg-dark-900 rounded-lg p-6">
              <h3 class="text-base font-bold text-white mb-5 uppercase tracking-wider">
                {lang === 'ur' ? 'اہم نکات' : 'Key Takeaways'}
              </h3>
              <ul class="space-y-4">
                <li class="flex items-start gap-3">
                  <span class="text-debt-red text-lg">→</span>
                  <span class="text-gray-200 text-base">{lang === 'ur' ? 'پاکستان اپنے بجٹ کا تقریباً دوگنا حصہ قرض کے سود پر خرچ کرتا ہے' : 'Pakistan spends nearly 2x more of its budget on debt interest'}</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-education-green text-lg">→</span>
                  <span class="text-gray-200 text-base">{lang === 'ur' ? 'بھارت تعلیم پر 4.5 گنا زیادہ خرچ کرتا ہے (فیصد کے لحاظ سے)' : 'India spends 4.5x more on education (as % of budget)'}</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-health-teal text-lg">→</span>
                  <span class="text-gray-200 text-base">{lang === 'ur' ? 'بھارت صحت پر 16 گنا زیادہ خرچ کرتا ہے (فیصد کے لحاظ سے)' : 'India spends 16x more on health (as % of budget)'}</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-psdp-green text-lg">→</span>
                  <span class="text-gray-200 text-base">{lang === 'ur' ? 'بھارت ترقی پر 2 گنا زیادہ خرچ کرتا ہے' : 'India spends 2x more on development & infrastructure'}</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-slate-300 text-lg">→</span>
                  <span class="text-gray-200 text-base">{lang === 'ur' ? 'پاکستان دفاع پر تقریباً 2 گنا زیادہ خرچ کرتا ہے (فیصد کے لحاظ سے)' : 'Pakistan spends ~2x more on defence (as % of budget)'}</span>
                </li>
              </ul>

              <!-- Stats boxes -->
              <div class="grid grid-cols-2 gap-3 mt-6">
                <div class="bg-dark-800 rounded p-3 text-center">
                  <p class="text-xs text-gray-500 uppercase">{lang === 'ur' ? 'پاکستان بجٹ' : 'Pakistan Budget'}</p>
                  <p class="text-lg font-bold text-white">Rs 17.6T</p>
                  <p class="text-xs text-gray-600">~$62B USD</p>
                </div>
                <div class="bg-dark-800 rounded p-3 text-center">
                  <p class="text-xs text-gray-500 uppercase">{lang === 'ur' ? 'بھارت بجٹ' : 'India Budget'}</p>
                  <p class="text-lg font-bold text-orange-500">₹50.6T</p>
                  <p class="text-xs text-gray-600">~$605B USD</p>
                </div>
                <div class="bg-dark-800 rounded p-3 text-center">
                  <p class="text-xs text-gray-500 uppercase">{lang === 'ur' ? 'پاکستان آبادی' : 'Pakistan Pop.'}</p>
                  <p class="text-lg font-bold text-white">240M</p>
                </div>
                <div class="bg-dark-800 rounded p-3 text-center">
                  <p class="text-xs text-gray-500 uppercase">{lang === 'ur' ? 'بھارت آبادی' : 'India Pop.'}</p>
                  <p class="text-lg font-bold text-orange-500">1.45B</p>
                </div>
              </div>

              <p class="text-xs text-gray-600 mt-4">
                {lang === 'ur' ? 'نوٹ: پاکستان کے اعداد صرف وفاقی بجٹ کے ہیں۔ صوبائی اخراجات علیحدہ ہیں۔' : 'Note: Pakistan figures are federal only. Provincial spending is separate.'}
              </p>
            </div>
          </div>
        </div>

        <!-- Category Filter -->
        <div class="mb-8 p-4 bg-dark-800 border border-white/10 rounded-lg">
          <p class="text-sm text-gray-400 mb-3">{lang === 'ur' ? 'زمرہ جات منتخب کریں:' : 'Select categories to display:'}</p>
          <div class="flex flex-wrap gap-2" id="category-filters">
            {Object.entries(categoryInfo).map(([key, info]) => (
              <button
                data-category={key}
                class="category-btn px-3 py-1.5 text-sm rounded-full border border-white/20 text-gray-300 hover:border-white/40 transition-colors active"
                style={`--cat-color: ${info.color}`}
              >
                <span class="cat-dot inline-block w-2.5 h-2.5 rounded-full mr-2 border border-white/30" style={`background-color: ${info.color}`}></span>
                {lang === 'ur' ? info.labelUrdu : info.label}
              </button>
            ))}
          </div>
        </div>

        <!-- Main Chart -->
        <div id="budget-chart" class="mb-12 p-6 bg-dark-800 border border-white/10 rounded-lg">
          <h2 class="text-xl font-bold mb-6 text-white">
            {lang === 'ur' ? 'بجٹ مختص (ٹریلین روپے میں)' : 'Budget Allocations (in Trillions PKR)'}
          </h2>
          <div class="relative" style="height: 450px;">
            <canvas id="compare-chart"></canvas>
          </div>
        </div>


        <!-- Data Table -->
        <div id="data-table" class="mb-12 p-6 bg-dark-800 border border-white/10 rounded-lg overflow-x-auto">
          <h2 class="text-xl font-bold mb-6 text-white">
            {lang === 'ur' ? 'تفصیلی اعداد و شمار (ارب روپے)' : 'Detailed Data (Billion PKR)'}
          </h2>
          <table class="w-full text-sm" id="data-table">
            <thead>
              <tr class="border-b border-white/10">
                <th class="text-left py-3 px-2 text-gray-400 font-medium">{lang === 'ur' ? 'مالی سال' : 'Fiscal Year'}</th>
                <th class="text-right py-3 px-2 text-gray-400 font-medium">{lang === 'ur' ? 'کل بجٹ' : 'Total'}</th>
                {Object.entries(categoryInfo).map(([key, info]) => (
                  <th class="text-right py-3 px-2 text-gray-400 font-medium" style={`color: ${info.color}`}>
                    {lang === 'ur' ? info.labelUrdu : info.label}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody id="table-body">
              <!-- Populated by JavaScript -->
            </tbody>
          </table>
        </div>

        <!-- Growth Analysis -->
        <div class="grid md:grid-cols-2 gap-6 mb-12">
          <div class="p-6 bg-dark-800 border border-white/10 rounded-lg">
            <h3 class="text-lg font-bold mb-4 text-white">
              {lang === 'ur' ? '10 سال میں اضافہ' : '10-Year Growth'}
            </h3>
            <div id="growth-stats" class="space-y-3">
              <!-- Populated by JavaScript -->
            </div>
          </div>

          <div class="p-6 bg-dark-800 border border-white/10 rounded-lg">
            <h3 class="text-lg font-bold mb-4 text-white">
              {lang === 'ur' ? 'اہم نکات' : 'Key Insights'}
            </h3>
            <ul class="space-y-3 text-gray-400">
              <li class="flex items-start gap-2">
                <span class="text-debt-red mt-1">●</span>
                <span>{lang === 'ur' ? 'قرض کا سود 10 سال میں 6.4 گنا بڑھ گیا' : 'Debt interest grew 6.4x in 10 years'}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-education-green mt-1">●</span>
                <span>{lang === 'ur' ? 'تعلیم صرف 1.7 گنا بڑھی — افراط زر سے بھی کم' : 'Education grew only 1.7x — below inflation'}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-health-teal mt-1">●</span>
                <span>{lang === 'ur' ? 'صحت بجٹ کا 0.13% — دنیا میں سب سے کم' : 'Health at 0.13% — among world\'s lowest'}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-gray-400 mt-1">●</span>
                <span>{lang === 'ur' ? 'قرض + دفاع = بجٹ کا 60% سے زیادہ' : 'Debt + Defence = over 60% of budget'}</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- PROVINCIAL BUDGETS -->
        <div id="provincial" class="mb-12 p-6 bg-dark-800 border border-white/10 rounded-lg">
          <h2 class="text-xl font-bold mb-2 text-white">
            {lang === 'ur' ? 'صوبائی بجٹ' : 'Provincial Budgets'}
          </h2>
          <p class="text-gray-500 text-sm mb-6">
            {lang === 'ur' ? 'مالی سال 2025-26 کے صوبائی بجٹ' : 'FY 2025-26 Provincial Budget Allocations'}
          </p>

          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Punjab -->
            <div class="bg-dark-900 rounded-lg p-4 border border-white/5">
              <h3 class="text-lg font-bold text-white mb-1">{lang === 'ur' ? 'پنجاب' : 'Punjab'}</h3>
              <p class="text-2xl font-bold text-nfc-blue mb-2">Rs 5.33T</p>
              <div class="text-xs text-gray-500 space-y-1">
                <div class="flex justify-between">
                  <span>{lang === 'ur' ? 'ترقیاتی بجٹ' : 'Development'}</span>
                  <span class="text-psdp-green">Rs 1.24T</span>
                </div>
                <div class="flex justify-between">
                  <span>{lang === 'ur' ? 'آبادی' : 'Population'}</span>
                  <span>~127M</span>
                </div>
              </div>
            </div>

            <!-- Sindh -->
            <div class="bg-dark-900 rounded-lg p-4 border border-white/5">
              <h3 class="text-lg font-bold text-white mb-1">{lang === 'ur' ? 'سندھ' : 'Sindh'}</h3>
              <p class="text-2xl font-bold text-nfc-blue mb-2">Rs 3.45T</p>
              <div class="text-xs text-gray-500 space-y-1">
                <div class="flex justify-between">
                  <span>{lang === 'ur' ? 'ترقیاتی بجٹ' : 'Development'}</span>
                  <span class="text-psdp-green">Rs 850B</span>
                </div>
                <div class="flex justify-between">
                  <span>{lang === 'ur' ? 'آبادی' : 'Population'}</span>
                  <span>~55M</span>
                </div>
              </div>
            </div>

            <!-- KPK -->
            <div class="bg-dark-900 rounded-lg p-4 border border-white/5">
              <h3 class="text-lg font-bold text-white mb-1">{lang === 'ur' ? 'خیبر پختونخوا' : 'KPK'}</h3>
              <p class="text-2xl font-bold text-nfc-blue mb-2">Rs 2.12T</p>
              <div class="text-xs text-gray-500 space-y-1">
                <div class="flex justify-between">
                  <span>{lang === 'ur' ? 'ترقیاتی بجٹ' : 'Development'}</span>
                  <span class="text-psdp-green">Rs 520B</span>
                </div>
                <div class="flex justify-between">
                  <span>{lang === 'ur' ? 'آبادی' : 'Population'}</span>
                  <span>~40M</span>
                </div>
              </div>
            </div>

            <!-- Balochistan -->
            <div class="bg-dark-900 rounded-lg p-4 border border-white/5">
              <h3 class="text-lg font-bold text-white mb-1">{lang === 'ur' ? 'بلوچستان' : 'Balochistan'}</h3>
              <p class="text-2xl font-bold text-nfc-blue mb-2">Rs 950B</p>
              <div class="text-xs text-gray-500 space-y-1">
                <div class="flex justify-between">
                  <span>{lang === 'ur' ? 'ترقیاتی بجٹ' : 'Development'}</span>
                  <span class="text-psdp-green">Rs 250B</span>
                </div>
                <div class="flex justify-between">
                  <span>{lang === 'ur' ? 'آبادی' : 'Population'}</span>
                  <span>~15M</span>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-6 p-4 bg-dark-900 rounded-lg">
            <p class="text-sm text-gray-300">
              <span class="text-white font-medium">{lang === 'ur' ? 'نوٹ:' : 'Note:'}</span>
              {lang === 'ur' ? ' صوبائی تعلیم اور صحت کے اخراجات یہاں شامل ہیں۔ صوبے وفاقی حکومت سے NFC ٹرانسفرز وصول کرتے ہیں۔' : ' Provincial education and health spending is included here. Provinces receive NFC transfers from federal government.'}
            </p>
          </div>
        </div>

        <!-- NFC EXPLANATION -->
        <div id="nfc-info" class="mb-12 p-6 bg-nfc-blue/10 border border-nfc-blue/30 rounded-lg">
          <h2 class="text-xl font-bold mb-3 text-white flex items-center gap-2">
            <span class="text-nfc-blue">?</span>
            {lang === 'ur' ? 'NFC کیا ہے؟' : 'What is NFC?'}
          </h2>
          <div class="text-gray-200 space-y-3">
            <p class="text-base">
              <strong class="text-nfc-blue">NFC (National Finance Commission)</strong> —
              {lang === 'ur'
                ? 'قومی مالیاتی کمیشن ایک آئینی ادارہ ہے جو فیصلہ کرتا ہے کہ وفاقی حکومت کی جمع کردہ ٹیکس آمدنی صوبوں میں کیسے تقسیم ہوگی۔'
                : 'The National Finance Commission is a constitutional body that decides how federal tax revenue is distributed among provinces.'}
            </p>
            <div class="grid sm:grid-cols-2 gap-4 mt-4">
              <div class="bg-dark-900 rounded p-4">
                <p class="text-sm font-bold text-nfc-blue mb-2">{lang === 'ur' ? 'کیسے کام کرتا ہے' : 'How it works'}</p>
                <p class="text-sm text-gray-300">
                  {lang === 'ur'
                    ? 'وفاقی حکومت ٹیکس جمع کرتی ہے → NFC فارمولے کے مطابق تقسیم → صوبوں کو حصہ ملتا ہے'
                    : 'Federal govt collects taxes → NFC formula divides it → Provinces receive their share'}
                </p>
              </div>
              <div class="bg-dark-900 rounded p-4">
                <p class="text-sm font-bold text-nfc-blue mb-2">{lang === 'ur' ? 'موجودہ تقسیم' : 'Current Split'}</p>
                <p class="text-sm text-gray-300">
                  {lang === 'ur'
                    ? 'صوبوں کو 57.5% ملتا ہے، وفاق کو 42.5% رہتا ہے'
                    : 'Provinces get 57.5%, Federal keeps 42.5%'}
                </p>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-3">
              {lang === 'ur'
                ? 'یہی وجہ ہے کہ "NFC Transfers" وفاقی بجٹ کا 18% ہے — یہ رقم صوبوں کو جاتی ہے جو اسے تعلیم، صحت اور دیگر خدمات پر خرچ کرتے ہیں۔'
                : 'This is why "NFC Transfers" is 18% of federal budget — this money goes to provinces who spend it on education, health, and other services.'}
            </p>
          </div>
        </div>

        <!-- INFLATION DATA -->
        <div id="inflation" class="mb-12 p-6 bg-dark-800 border border-white/10 rounded-lg">
          <h2 class="text-xl font-bold mb-2 text-white">
            {lang === 'ur' ? '10 سال کی مہنگائی' : '10-Year Inflation'}
          </h2>
          <p class="text-gray-500 text-sm mb-6">
            {lang === 'ur' ? 'سالانہ افراط زر کی شرح (%) — ورلڈ بینک اور پاکستان بیورو آف سٹیٹسٹکس' : 'Annual inflation rate (%) — World Bank & Pakistan Bureau of Statistics'}
          </p>

          <div class="relative" style="height: 300px;">
            <canvas id="inflation-chart"></canvas>
          </div>

          <div class="mt-6 grid sm:grid-cols-3 gap-4">
            <div class="bg-dark-900 rounded-lg p-4 text-center">
              <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">{lang === 'ur' ? 'مجموعی مہنگائی' : 'Cumulative Inflation'}</p>
              <p class="text-2xl font-bold text-debt-red">185.6%</p>
              <p class="text-xs text-gray-600 mt-1">{lang === 'ur' ? '2015 سے 2025 تک' : '2015 to 2025'}</p>
            </div>
            <div class="bg-dark-900 rounded-lg p-4 text-center">
              <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">{lang === 'ur' ? 'سب سے زیادہ' : 'Peak Rate'}</p>
              <p class="text-2xl font-bold text-debt-red">29.2%</p>
              <p class="text-xs text-gray-600 mt-1">FY 2022-23</p>
            </div>
            <div class="bg-dark-900 rounded-lg p-4 text-center">
              <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">{lang === 'ur' ? 'موجودہ شرح' : 'Current Rate'}</p>
              <p class="text-2xl font-bold text-education-green">4.5%</p>
              <p class="text-xs text-gray-600 mt-1">FY 2025-26 (proj.)</p>
            </div>
          </div>

          <div class="mt-4 p-4 bg-debt-red/10 border border-debt-red/20 rounded-lg">
            <p class="text-sm text-gray-300">
              <span class="text-debt-red font-bold">{lang === 'ur' ? 'مطلب:' : 'What this means:'}</span>
              {lang === 'ur' ? '2015 میں 100 روپے کی چیز اب 285 روپے کی ہے۔ تنخواہیں اسی رفتار سے نہیں بڑھیں۔' : 'Something that cost Rs 100 in 2015 now costs Rs 285. Wages haven\'t kept pace.'}
            </p>
          </div>
        </div>

        <!-- Back to Home -->
        <div class="pt-8 border-t border-white/10">
          <a
            href={`/${lang === 'ur' ? '?lang=ur' : ''}`}
            class="inline-flex items-center gap-2 text-debt-red hover:text-red-400 font-medium transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            {lang === 'ur' ? 'واپس ہوم پیج' : 'Back to Home'}
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    if (typeof Chart === 'undefined') {
      console.error('Chart.js not loaded');
      return;
    }

    // Fetch budget data
    const response = await fetch('/data/budget.json');
    const budgetData = await response.json();
    const historicalData = budgetData.historicalData;

    const categoryInfo = {
      debtInterest: { label: 'Debt Servicing', color: '#ef4444' },
      nfcTransfers: { label: 'NFC Transfers', color: '#3b82f6' },
      defence: { label: 'Defence', color: '#94a3b8' },
      militaryPensions: { label: 'Military Pensions', color: '#78716c' },
      psdp: { label: 'Development (PSDP)', color: '#84cc16' },
      education: { label: 'Education', color: '#22c55e' },
      health: { label: 'Health', color: '#14b8a6' },
      other: { label: 'Other', color: '#6b7280' }
    };

    const categoryKeys = Object.keys(categoryInfo);
    let activeCategories = [...categoryKeys];

    // Convert to billions
    const toBillion = (v) => v / 1_000_000_000;
    const toTrillion = (v) => v / 1_000_000_000_000;

    // Build datasets for line chart
    function buildDatasets() {
      return categoryKeys.map(key => ({
        label: categoryInfo[key].label,
        data: historicalData.map(d => toTrillion(d[key] || 0)),
        borderColor: categoryInfo[key].color,
        backgroundColor: categoryInfo[key].color + '20',
        fill: false,
        tension: 0.3,
        borderWidth: 2,
        hidden: !activeCategories.includes(key)
      }));
    }


    // Main chart
    const ctx = document.getElementById('compare-chart');
    const mainChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: historicalData.map(d => d.fiscalYear),
        datasets: buildDatasets()
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          intersect: false,
          mode: 'index'
        },
        plugins: {
          legend: {
            display: false
          },
          tooltip: {
            backgroundColor: '#1a1a1d',
            titleColor: '#fff',
            bodyColor: '#9ca3af',
            borderColor: 'rgba(255,255,255,0.1)',
            borderWidth: 1,
            callbacks: {
              label: function(context) {
                return context.dataset.label + ': Rs ' + context.parsed.y.toFixed(2) + ' trillion';
              }
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              color: '#6b7280',
              callback: function(value) {
                return 'Rs ' + value + 'T';
              }
            },
            grid: {
              color: 'rgba(255,255,255,0.05)'
            }
          },
          x: {
            ticks: { color: '#6b7280' },
            grid: { display: false }
          }
        }
      }
    });

    // Populate data table
    const tableBody = document.getElementById('table-body');
    historicalData.forEach(d => {
      const row = document.createElement('tr');
      row.className = 'border-b border-white/5 hover:bg-white/5';
      row.innerHTML = `
        <td class="py-3 px-2 text-white font-medium">${d.fiscalYear}</td>
        <td class="py-3 px-2 text-right text-gray-300">${toBillion(d.totalBudget).toLocaleString()}</td>
        ${categoryKeys.map(key => `
          <td class="py-3 px-2 text-right text-gray-400">${toBillion(d[key] || 0).toLocaleString()}</td>
        `).join('')}
      `;
      tableBody.appendChild(row);
    });

    // Calculate growth stats
    const firstYear = historicalData[0];
    const lastYear = historicalData[historicalData.length - 1];
    const growthStats = document.getElementById('growth-stats');

    categoryKeys.forEach(key => {
      const growth = (lastYear[key] / firstYear[key]).toFixed(1);
      const div = document.createElement('div');
      div.className = 'flex justify-between items-center';
      div.innerHTML = `
        <span class="text-gray-400">
          <span class="inline-block w-2 h-2 rounded-full mr-2" style="background-color: ${categoryInfo[key].color}"></span>
          ${categoryInfo[key].label}
        </span>
        <span class="font-bold" style="color: ${categoryInfo[key].color}">${growth}x</span>
      `;
      growthStats.appendChild(div);
    });

    // Inflation chart
    const inflationData = budgetData.inflationData?.annual || [];
    if (inflationData.length > 0) {
      const inflationCtx = document.getElementById('inflation-chart');
      if (inflationCtx) {
        new Chart(inflationCtx, {
          type: 'line',
          data: {
            labels: inflationData.map(d => d.fiscalYear),
            datasets: [{
              label: 'Inflation Rate',
              data: inflationData.map(d => d.rate),
              borderColor: '#ef4444',
              backgroundColor: 'rgba(239, 68, 68, 0.1)',
              fill: true,
              tension: 0.3,
              borderWidth: 3,
              pointBackgroundColor: '#ef4444',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              pointRadius: 5
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: '#1a1a1d',
                titleColor: '#fff',
                bodyColor: '#9ca3af',
                callbacks: {
                  label: function(context) {
                    return 'Inflation: ' + context.parsed.y + '%';
                  }
                }
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                ticks: {
                  color: '#6b7280',
                  callback: function(value) { return value + '%'; }
                },
                grid: { color: 'rgba(255,255,255,0.05)' }
              },
              x: {
                ticks: { color: '#6b7280' },
                grid: { display: false }
              }
            }
          }
        });
      }
    }

    // Category filter buttons
    const filterBtns = document.querySelectorAll('.category-btn');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category;
        btn.classList.toggle('active');

        if (btn.classList.contains('active')) {
          activeCategories.push(cat);
          btn.style.backgroundColor = 'var(--cat-color)';
          btn.style.color = '#fff';
          btn.style.borderColor = 'var(--cat-color)';
        } else {
          activeCategories = activeCategories.filter(c => c !== cat);
          btn.style.backgroundColor = 'transparent';
          btn.style.color = '#d1d5db';
          btn.style.borderColor = 'rgba(255,255,255,0.2)';
        }

        // Update chart
        mainChart.data.datasets = buildDatasets();
        mainChart.update();
      });

      // Initialize active state styling
      if (btn.classList.contains('active')) {
        btn.style.backgroundColor = 'var(--cat-color)';
        btn.style.color = '#fff';
        btn.style.borderColor = 'var(--cat-color)';
      }
    });
  });
</script>

<style>
  .category-btn {
    transition: all 0.2s ease;
  }

  .category-btn.active {
    background-color: var(--cat-color);
    color: #fff;
    border-color: var(--cat-color);
  }

  .category-btn.active .cat-dot {
    background-color: white !important;
    border-color: white !important;
  }
</style>
